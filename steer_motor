/* --- Motor & Hardware Definitions --- */
#define MOTOR_DIR_PIN           GPIO_PIN_1
#define MOTOR_DIR_PORT          GPIOA
#define MOTOR_ENABLE_PIN        GPIO_PIN_4
#define MOTOR_ENABLE_PORT       GPIOA
#define MCP2515_CS_PIN          GPIO_PIN_0
#define MCP2515_CS_PORT         GPIOB
#define MCP2515_INT_PIN         GPIO_PIN_1
#define MCP2515_INT_PORT        GPIOB

#define ENCODER_PPR             1000
#define ENCODER_COUNTS_PER_REV  (ENCODER_PPR * 4)
#define ENCODER_MID_COUNT       (ENCODER_COUNTS_PER_REV / 2)
#define ROAD_WHEEL_MAX_DEG      34.0f
#define STEERING_RATIO          2.35f
#define CAN_ID_TARGET_ANGLE     0x100

/* --- Peripherals --- */
SPI_HandleTypeDef hspi1;
TIM_HandleTypeDef htim1; // Encoder
TIM_HandleTypeDef htim2; // Motor PWM
TIM_HandleTypeDef htim3; // 10ms Control Loop Timer

/* --- State Variables --- */
volatile uint32_t system_tick_ms          = 0;
volatile bool     control_loop_flag       = false;
volatile float    target_road_wheel_angle = 0.0f;

/* --- Function Prototypes --- */
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_SPI1_Init(void);
static void MX_TIM1_Init(void);
static void MX_TIM2_Init(void);
static void MX_TIM3_Init(void);

static void Read_Encoder(float *angle_deg);
static void Set_Motor_Direction(uint8_t direction);
static void Set_Step_Frequency(uint32_t pulses_per_cycle);

int main(void)
{
  HAL_Init();
  SystemClock_Config();

  MX_GPIO_Init();
  MX_SPI1_Init();
  MX_TIM1_Init();
  MX_TIM2_Init();
  MX_TIM3_Init();

  /* 1. Start Encoder Hardware */
  HAL_TIM_Encoder_Start(&htim1, TIM_CHANNEL_ALL);
  __HAL_TIM_SET_COUNTER(&htim1, ENCODER_MID_COUNT);

  /* 2. Start Motor PWM Hardware */
  HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_1);
  __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, 0);

  /* 3. Initialize CAN & PID */
  MCP2515_Init(&hspi1);
  PID_Init(0.0f, 0.0f, 0.0f); // Adjust Kp, Ki, Kd inside your sbw_pid_controller.c

  /* Enable Motor Torque */
  HAL_GPIO_WritePin(MOTOR_ENABLE_PORT, MOTOR_ENABLE_PIN, GPIO_PIN_RESET);

  /* 4. Start 10ms Control Loop Timer */
  HAL_TIM_Base_Start_IT(&htim3);

  while (1)
  {
    /* The 10ms Control Loop */
    if (control_loop_flag)
    {
      control_loop_flag = false;

      float measured_angle = 0.0f;
      Read_Encoder(&measured_angle);

      /* Calculate PID based on the latest CAN target */
      PID_Update(target_road_wheel_angle, measured_angle, system_tick_ms);

      /* Get PID output state and actuate motor */
      SBW_State_t state;
      SBW_GetState(&state);

      Set_Motor_Direction(state.direction);
      Set_Step_Frequency((uint32_t)state.step_pulses);
    }
  }
}

/* --- INTERRUPT CALLBACKS --- */

void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
  if (GPIO_Pin == MCP2515_INT_PIN)
  {
    uint32_t rx_id  = 0;
    uint8_t  rx_data[8] = {0};
    uint8_t  rx_len = 0;

    if (MCP2515_ReadMessage(&rx_id, rx_data, &rx_len))
    {
      if (rx_id == CAN_ID_TARGET_ANGLE && rx_len == 4)
      {
        float angle;
        memcpy(&angle, rx_data, 4);

        /* Hardware limit safeguard */
        if (angle >= -ROAD_WHEEL_MAX_DEG && angle <= ROAD_WHEEL_MAX_DEG)
        {
          target_road_wheel_angle = angle;
        }
      }
    }
  }
}

void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
  if (htim->Instance == TIM3)
  {
    system_tick_ms += 10;
    control_loop_flag = true;
  }
}

/* --- MOTOR CONTROL FUNCTIONS --- */

static void Read_Encoder(float *angle_deg)
{
  uint32_t raw = __HAL_TIM_GET_COUNTER(&htim1);
  int32_t  rel = (int32_t)raw - (int32_t)ENCODER_MID_COUNT;
  float counts_per_deg = ((float)ENCODER_COUNTS_PER_REV / 360.0f) * STEERING_RATIO;
  *angle_deg = (float)rel / counts_per_deg;
}

static void Set_Motor_Direction(uint8_t direction)
{
  HAL_GPIO_WritePin(MOTOR_DIR_PORT, MOTOR_DIR_PIN,
                   (direction == 0) ? GPIO_PIN_RESET : GPIO_PIN_SET);
}

static void Set_Step_Frequency(uint32_t pulses_per_cycle)
{
  if (pulses_per_cycle == 0)
  {
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, 0);
    return;
  }
  uint32_t period = __HAL_TIM_GET_AUTORELOAD(&htim2);
  uint32_t duty   = (pulses_per_cycle * (period / 2)) / 2000;

  if (duty == 0) duty = 1;
  if (duty > period / 2) duty = period / 2;

  __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, duty);
}

